generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Activity {
  id          String        @id
  name        String
  zoneId      String
  componentId String
  projectId   String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  component   Component     @relation(fields: [componentId], references: [id], onDelete: Cascade)
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  zone        Zone          @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  timeEntries TimeEntry[]

  @@map("activities")
}

model Component {
  id                String              @id
  code              String              @unique
  name              String
  category          String
  createdAt         DateTime            @default(now())
  activities        Activity[]
  projectComponents ProjectComponent[]

  @@map("components")
}

model ProjectComponent {
  id          String    @id
  projectId   String
  componentId String
  createdAt   DateTime  @default(now())
  component   Component @relation(fields: [componentId], references: [id], onDelete: Cascade)
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, componentId])
  @@map("project_components")
}

model ProjectMember {
  id        String   @id
  projectId String
  userId    String
  createdAt DateTime @default(now())
  role      String?
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model Project {
  id                String              @id
  name              String
  date              DateTime            @db.Date
  status            ProjectStatus       @default(DRAFT)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  activities        Activity[]
  projectComponents ProjectComponent[]
  members           ProjectMember[]
  timeEntries       TimeEntry[]
  zones             Zone[]

  @@map("projects")
}

model Task {
  id          String      @id
  name        String      @unique
  status      TaskStatus  @default(ACTIVE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime
  timeEntries TimeEntry[]

  @@map("tasks")
}

model TimeEntry {
  id                String    @id
  userId            String
  taskId            String
  date              DateTime  @db.Date
  hours             Decimal   @db.Decimal(4, 2)
  startTime         String?
  endTime           String?
  comment           String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime
  projectId         String?
  activityId        String?
  componentId       String?
  wastedHoursReason String?
  zoneId            String?
  activity          Activity? @relation(fields: [activityId], references: [id])
  project           Project?  @relation(fields: [projectId], references: [id])
  task              Task      @relation(fields: [taskId], references: [id])
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("time_entries")
}

model User {
  id              String          @id
  name            String
  email           String          @unique
  passwordHash    String?
  role            Role            @default(EMPLOYEE)
  status          UserStatus      @default(PENDING)
  inviteToken     String?         @unique
  inviteExpiry    DateTime?
  resetToken      String?         @unique
  resetExpiry     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  jobTitle        String?
  projectMembers  ProjectMember[]
  timeEntries     TimeEntry[]

  @@map("users")
}

model Zone {
  id         String     @id
  name       String
  projectId  String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime
  activities Activity[]
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("zones")
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum TaskStatus {
  ACTIVE
  INACTIVE
}

enum UserStatus {
  PENDING
  ACTIVE
  DISABLED
}
